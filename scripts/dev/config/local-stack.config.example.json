{
  "database": {
    "name": "terria_v1_local",
    "host": "127.0.0.1",
    "port": 3306,
    "username": "root",
    "password": "set-your-local-db-password"
  },
  "redis": {
    "host": "127.0.0.1",
    "port": 6380,
    "database": 0,
    "password": "set-your-local-redis-password",
    "serverExe": "G:\\Redis\\redis-server.exe"
  },
  "backend": {
    "port": 18088
  },
  "front": {
    "port": 5174
  },
  "admin": {
    "port": 3001
  },
  "auth": {
    "admin": {
      "username": "admin",
      "password": "set-a-local-admin-password",
      "displayName": "Admin",
      "tokenSecret": "set-a-local-admin-token-secret"
    },
    "user": {
      "tokenSecret": "set-a-local-user-token-secret"
    }
  },
  "minio": {
    "enabled": false,
    "credentialsFile": "scripts/dev/config/credentials.json",
    "endpoint": "http://127.0.0.1:9000",
    "publicEndpoint": "http://localhost:9000",
    "bucket": "terrapedia-images",
    "objectPrefix": "items",
    "dataDir": "~/.local/share/terrapedia/minio/data",
    "consolePort": 19001
  },
  "dataRefresh": {
    "enabled": false,
    "mode": "apply",
    "intervalMinutes": 180,
    "startupDelaySeconds": 30,
    "heartbeatSeconds": 15,
    "staleLockMinutes": 360,
    "resume": true,
    "timeoutMs": 1200000,
    "steps": "",
    "reportDir": "reports/backend-refresh/history",
    "lockFile": "reports/backend-refresh/backend-refresh.lock.json",
    "stateFile": "reports/backend-refresh/backend-refresh-scheduler.latest.json",
    "heartbeatFile": "reports/backend-refresh/backend-refresh-daemon.heartbeat.json"
  }
}
